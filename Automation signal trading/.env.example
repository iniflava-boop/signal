# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_DRY_RUN=true

# Market data
TOP_SYMBOL_LIMIT=50
MIN_QUOTE_VOLUME_USDT=50000000
MAX_SPREAD_BPS=15

# Signal engine
TIMEFRAME=4h
CONFIRMATION_TIMEFRAME=1d
CONFIDENCE_THRESHOLD=70
SCAN_INTERVAL_MINUTES=240
ENTRY_ZONE_ATR_MULTIPLIER=0.15
