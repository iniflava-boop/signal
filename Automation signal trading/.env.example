# RSS news, comma-separated
RSS_FEEDS=https://cointelegraph.com/rss,https://decrypt.co/feed,https://www.coindesk.com/arc/outboundfeeds/rss/

# Storage
DATABASE_PATH=data/signals.sqlite3
